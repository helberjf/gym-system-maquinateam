{
  "name": "maquinateam-gym-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "db:format": "prisma format",
    "db:generate": "prisma generate",
    "db:push": "node scripts/run-with-direct-url.cjs npx prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "node scripts/run-with-direct-url.cjs npx prisma migrate deploy",
    "db:status": "node scripts/run-with-direct-url.cjs npx prisma migrate status",
    "db:seed": "prisma db seed",
    "db:seed:direct": "node scripts/run-with-direct-url.cjs npx tsx prisma/seed.ts",
    "db:populate-plans": "tsx scripts/populate-plans.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^6.0.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/nodemailer": "^8.0.0",
    "@upstash/qstash": "^2.10.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^1.7.0",
    "mercadopago": "^2.10.0",
    "next": "^16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^8.0.5",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.54.0",
    "resend": "^6.12.0",
    "sonner": "^2.0.7",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "fast-check": "^4.7.0",
    "postcss": "^8.5.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  }
}
