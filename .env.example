# ============================================================
# Maquina Team Gym System — .env.example
# Copie para .env.local e preencha com seus valores reais.
# NUNCA commite o .env.local com valores reais.
# ============================================================

# --- Banco de dados (PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/maquinateam?sslmode=require"

# --- Auth.js v5 ---
NEXTAUTH_SECRET="gere-um-segredo-forte-aqui"  # openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# --- Mercado Pago ---
MP_ACCESS_TOKEN="APP_USR-..."
MP_PUBLIC_KEY="APP_USR-..."
MP_INTEGRATOR_ID="dev_24c65fb163bf11ea96500242ac130004"
MP_MAX_INSTALLMENTS=6
MP_WEBHOOK_SECRET="sua-chave-secreta-para-validar-webhook"

# --- Cloudflare R2 (Fase 6) ---
