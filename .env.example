# ============================================================
# Maquina Team Gym System
# Copie para `.env` e replique no `.env.local` quando precisar.
# ============================================================

# --- Banco de dados (PostgreSQL + Prisma) ---
# Runtime/app: use a URL pooled. No Supabase, prefira o pooler com porta 6543.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maquinateam?schema=public"
# Schema/migrations: use uma conexao direta. No Supabase, use a porta 5432.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/maquinateam?schema=public"

# --- Auth.js v5 ---
# Em producao na Vercel, use o dominio final publicado.
AUTH_SECRET="gere-um-segredo-forte-aqui"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Compatibilidade local
NEXTAUTH_SECRET="gere-um-segredo-forte-aqui"
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth ---
# Callback esperada: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Resend ---
# Use um remetente de um dominio verificado no painel do Resend.
RESEND_API_KEY=""
RESEND_FROM="Maquina Team <noreply@seudominio.com>"
# Opcional: alternativa ao RESEND_FROM completo.
RESEND_FROM_NAME="Maquina Team"
RESEND_FROM_EMAIL="noreply@seudominio.com"

# --- Rate limit distribuido (recomendado para Vercel/producao) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Mercado Pago ---
MP_ACCESS_TOKEN="APP_USR-..."
MP_PUBLIC_KEY="APP_USR-..."
MP_INTEGRATOR_ID="dev_24c65fb163bf11ea96500242ac130004"
MP_MAX_INSTALLMENTS=6
MP_WEBHOOK_SECRET="sua-chave-secreta-para-validar-webhook"
MP_WEBHOOK_ALLOWED_IPS=""
MP_STORE_STATEMENT_DESCRIPTOR="MAQUINATEAM"
MP_PLAN_STATEMENT_DESCRIPTOR="MAQUINATEAM"

# --- AbacatePay (PIX) ---
ABACATEPAY_API_KEY=""
ABACATEPAY_BASE_URL="https://api.abacatepay.com"

# --- Seed local ---
SEED_ADMIN_PASSWORD="Admin@123"
SEED_STAFF_PASSWORD="Equipe@123"
SEED_STUDENT_PASSWORD="Aluno@123"

# --- Cloudflare R2 (uploads de produtos) ---
# Preencha R2_ENDPOINT ou deixe vazio para derivar automaticamente de R2_ACCOUNT_ID.
R2_ACCOUNT_ID=""
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Prefira um dominio customizado para producao em vez de r2.dev.
R2_PUBLIC_URL=""
# Usado pelo Next.js para carregar imagens publicas da loja e do dashboard.
NEXT_PUBLIC_R2_PUBLIC_URL=""

# --- App ---
# Em producao, alinhe com o mesmo dominio do AUTH_URL.
# Tambem e usado na navegacao publica da loja e nos retornos do checkout.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Maquina Team"

# --- Observabilidade ---
# debug | info | warn | error. Padrao: info em producao, debug fora.
LOG_LEVEL=""
# Opcional. Recebe alertas JSON de erros criticos e jobs com falha.
ALERT_WEBHOOK_URL=""
# Opcional. Preenchido, habilita envio a Sentry via instrumentation.ts.
# Requer "npm i @sentry/nextjs" e descomentar o bloco em instrumentation.ts.
SENTRY_DSN=""

# --- Tarefas agendadas externas ---
# Os Vercel Cron Jobs ficam desativados em vercel.json. Use QStash, GitHub Actions
# ou outro scheduler externo chamando /api/cron/* com Authorization: Bearer CRON_SECRET.
CRON_SECRET=""
