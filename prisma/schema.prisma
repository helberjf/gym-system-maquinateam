generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  RECEPCAO
  PROFESSOR
  ALUNO
}

enum StudentStatus {
  PENDING
  ACTIVE
  TRIAL
  SUSPENDED
  INACTIVE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  CASH
  BANK_TRANSFER
  BOLETO
}

enum PaymentProvider {
  MERCADO_PAGO
  ABACATEPAY
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELLED
  EXPIRED
}

enum AttendanceStatus {
  PENDING
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
  CANCELLED
}

enum TrainingAssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  MISSED
  CANCELLED
}

enum ProductStatus {
  ACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum SaleStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum DeliveryMethod {
  PICKUP
  LOCAL_DELIVERY
  STANDARD_SHIPPING
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum InventoryMovementType {
  ORDER_RESERVE
  ORDER_RESTORE
  MANUAL_ADJUSTMENT
}

enum CheckoutPaymentKind {
  STORE_ORDER
  PLAN_SUBSCRIPTION
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  INSTAGRAM
  WHATSAPP
  REFERRAL
  WALK_IN
  PHONE
  SOCIAL_MEDIA
  OTHER
}

enum LeadInteractionType {
  NOTE
  CALL
  EMAIL
  WHATSAPP
  MEETING
  INSTAGRAM_DM
}

enum LeadTaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum LeadTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReviewTargetType {
  TEACHER
  MODALITY
  CLASS_SCHEDULE
  FACILITY
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationTone {
  INFO
  SUCCESS
  WARNING
  DANGER
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_OVERDUE
  PAYMENT_RECEIVED
  CLASS_REMINDER
  CLASS_CANCELLED
  TRAINING_ASSIGNED
  TRAINING_DUE
  ANNOUNCEMENT
  REVIEW_PENDING_MODERATION
  LEAD_ASSIGNED
  STOCK_LOW
  WEBHOOK_FAILED
  GENERIC
}

model User {
  id                       String               @id @default(cuid())
  name                     String
  email                    String               @unique
  emailVerified            DateTime?
  passwordHash             String?
  role                     UserRole             @default(ALUNO)
  image                    String?
  phone                    String?
  isActive                 Boolean              @default(true)
  lastLoginAt              DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  accounts                 Account[]
  sessions                 Session[]
  passwordResetTokens      PasswordResetToken[]
  studentProfile           StudentProfile?
  teacherProfile           TeacherProfile?
  createdSubscriptions     Subscription[]       @relation("SubscriptionCreatedBy")
  createdPayments          Payment[]            @relation("PaymentCreatedBy")
  processedPayments        Payment[]            @relation("PaymentProcessedBy")
  checkedInAttendances     Attendance[]         @relation("AttendanceCheckedInBy")
  checkedOutAttendances    Attendance[]         @relation("AttendanceCheckedOutBy")
  createdAnnouncements     Announcement[]       @relation("AnnouncementCreatedBy")
  auditLogs                AuditLog[]           @relation("AuditLogActor")
  productSales             ProductSale[]        @relation("ProductSaleSoldBy")
  createdEnrollments       ClassEnrollment[]    @relation("ClassEnrollmentCreatedBy")
  storeCart                Cart?
  wishlist                 Wishlist?
  shippingAddresses        ShippingAddress[]
  orders                   Order[]
  couponRedemptions        CouponRedemption[]
  inventoryMovements       InventoryMovement[]  @relation("InventoryMovementPerformedBy")
  orderStatusHistory       OrderStatusHistory[] @relation("OrderStatusChangedBy")
  checkoutPayments         CheckoutPayment[]
  createdExpenses          Expense[]            @relation("ExpenseCreatedBy")
  createdNutritionPlans    NutritionPlan[]      @relation("NutritionPlanCreatedBy")
  whatsAppMessagesSent     WhatsAppMessage[]    @relation("WhatsAppSentBy")
  whatsAppTemplatesCreated WhatsAppTemplate[]   @relation("WhatsAppTemplateCreatedBy")
  leadsAssigned            Lead[]               @relation("LeadAssignedTo")
  leadsCreated             Lead[]               @relation("LeadCreatedBy")
  leadInteractions         LeadInteraction[]    @relation("LeadInteractionBy")
  leadTasksAssigned        LeadTask[]           @relation("LeadTaskAssignedTo")
  leadTasksCreated         LeadTask[]           @relation("LeadTaskCreatedBy")
  appSettingsUpdated       AppSetting[]         @relation("AppSettingUpdatedBy")
  reviewsAuthored          Review[]             @relation("ReviewAuthor")
  reviewsModerated         Review[]             @relation("ReviewModerator")
  notifications            Notification[]
  pushSubscriptions        PushSubscription[]

  @@index([role, isActive])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model StudentProfile {
  id                    String                 @id @default(cuid())
  userId                String                 @unique
  registrationNumber    String                 @unique
  status                StudentStatus          @default(ACTIVE)
  primaryModalityId     String?
  responsibleTeacherId  String?
  birthDate             DateTime?              @db.Date
  cpf                   String?                @unique
  addressLine           String?
  city                  String?
  state                 String?
  zipCode               String?
  emergencyContactName  String?
  emergencyContactPhone String?
  medicalNotes          String?                @db.Text
  goals                 String?                @db.Text
  notes                 String?                @db.Text
  joinedAt              DateTime               @default(now())
  beltLevel             String?
  weightKg              Float?
  heightCm              Int?
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryModality       Modality?              @relation("StudentPrimaryModality", fields: [primaryModalityId], references: [id], onDelete: SetNull)
  responsibleTeacher    TeacherProfile?        @relation("StudentResponsibleTeacher", fields: [responsibleTeacherId], references: [id], onDelete: SetNull)
  enrollments           ClassEnrollment[]
  subscriptions         Subscription[]
  payments              Payment[]
  attendances           Attendance[]
  trainingAssignments   TrainingAssignment[]
  productSales          ProductSale[]
  physicalAssessments   PhysicalAssessment[]
  gamification          StudentGamification?
  earnedBadges          StudentBadge[]
  pointsHistory         GamificationEvent[]
  nutritionPlans        NutritionPlan[]
  whatsAppConversations WhatsAppConversation[]
  whatsappOptIn         Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([status])
  @@index([primaryModalityId])
  @@index([responsibleTeacherId])
  @@map("student_profiles")
}

model TeacherProfile {
  id                   String                @id @default(cuid())
  userId               String                @unique
  registrationNumber   String?               @unique
  cpf                  String?               @unique
  bio                  String?               @db.Text
  specialties          String?
  experienceYears      Int?
  hireDate             DateTime?             @db.Date
  hourlyRateCents      Int?
  beltLevel            String?
  notes                String?               @db.Text
  isActive             Boolean               @default(true)
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  modalities           Modality[]
  classes              ClassSchedule[]
  trainingTemplates    TrainingTemplate[]
  assignedTrainings    TrainingAssignment[]  @relation("TrainingAssignmentTeacher")
  responsibleStudents  StudentProfile[]      @relation("StudentResponsibleTeacher")
  assessmentsConducted PhysicalAssessment[]  @relation("AssessmentEvaluator")
  availabilities       TeacherAvailability[]
  timeOffs             TeacherTimeOff[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([isActive])
  @@map("teacher_profiles")
}

model Modality {
  id                String             @id @default(cuid())
  name              String             @unique
  slug              String             @unique
  description       String?            @db.Text
  colorHex          String?
  isActive          Boolean            @default(true)
  sortOrder         Int                @default(0)
  teachers          TeacherProfile[]
  classSchedules    ClassSchedule[]
  classEnrollments  ClassEnrollment[]
  primaryStudents   StudentProfile[]   @relation("StudentPrimaryModality")
  plans             Plan[]
  trainingTemplates TrainingTemplate[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([isActive, sortOrder])
  @@map("modalities")
}

model ClassSchedule {
  id               String            @id @default(cuid())
  modalityId       String
  teacherProfileId String
  title            String
  description      String?           @db.Text
  dayOfWeek        Int
  daysOfWeek       Int[]             @default([])
  startTime        String
  endTime          String
  room             String?
  capacity         Int?
  isActive         Boolean           @default(true)
  validFrom        DateTime?         @db.Date
  validUntil       DateTime?         @db.Date
  modality         Modality          @relation(fields: [modalityId], references: [id], onDelete: Restrict)
  teacherProfile   TeacherProfile    @relation(fields: [teacherProfileId], references: [id], onDelete: Restrict)
  enrollments      ClassEnrollment[]
  attendances      Attendance[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([id, modalityId])
  @@index([isActive, dayOfWeek, startTime])
  @@index([modalityId, dayOfWeek, startTime])
  @@index([teacherProfileId, dayOfWeek, startTime])
  @@map("class_schedules")
}

model ClassEnrollment {
  id               String         @id @default(cuid())
  studentProfileId String
  classScheduleId  String
  modalityId       String
  enrolledAt       DateTime       @default(now())
  startsAt         DateTime?      @db.Date
  endsAt           DateTime?      @db.Date
  isActive         Boolean        @default(true)
  notes            String?        @db.Text
  createdByUserId  String?
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  modality         Modality       @relation(fields: [modalityId], references: [id], onDelete: Restrict)
  classSchedule    ClassSchedule  @relation(fields: [classScheduleId, modalityId], references: [id, modalityId], onDelete: Restrict)
  createdByUser    User?          @relation("ClassEnrollmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([studentProfileId, classScheduleId])
  @@index([modalityId, isActive])
  @@index([classScheduleId])
  @@map("class_enrollments")
}

model Plan {
  id                    String            @id @default(cuid())
  name                  String
  slug                  String            @unique
  description           String?           @db.Text
  benefits              String[]          @default([])
  modalityId            String?
  priceCents            Int
  billingIntervalMonths Int               @default(1)
  durationMonths        Int?
  sessionsPerWeek       Int?
  isUnlimited           Boolean           @default(false)
  enrollmentFeeCents    Int               @default(0)
  active                Boolean           @default(true)
  modality              Modality?         @relation(fields: [modalityId], references: [id], onDelete: SetNull)
  subscriptions         Subscription[]
  checkoutPayments      CheckoutPayment[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([active])
  @@index([modalityId])
  @@map("plans")
}

model Subscription {
  id               String             @id @default(cuid())
  studentProfileId String
  planId           String
  status           SubscriptionStatus @default(ACTIVE)
  startDate        DateTime           @db.Date
  endDate          DateTime?          @db.Date
  renewalDay       Int?
  autoRenew        Boolean            @default(false)
  priceCents       Int
  discountCents    Int                @default(0)
  notes            String?            @db.Text
  cancelledAt      DateTime?
  createdByUserId  String?
  studentProfile   StudentProfile     @relation(fields: [studentProfileId], references: [id], onDelete: Restrict)
  plan             Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments         Payment[]
  checkoutPayment  CheckoutPayment?
  createdByUser    User?              @relation("SubscriptionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([id, studentProfileId])
  @@index([studentProfileId, status])
  @@index([planId])
  @@index([startDate, endDate])
  @@map("subscriptions")
}

model Payment {
  id                   String         @id @default(cuid())
  studentProfileId     String
  subscriptionId       String
  amountCents          Int
  status               PaymentStatus  @default(PENDING)
  method               PaymentMethod
  dueDate              DateTime?      @db.Date
  paidAt               DateTime?
  externalReference    String?        @unique
  gatewayTransactionId String?        @unique
  description          String?
  notes                String?        @db.Text
  createdByUserId      String?
  processedByUserId    String?
  studentProfile       StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Restrict)
  subscription         Subscription   @relation(fields: [subscriptionId, studentProfileId], references: [id, studentProfileId], onDelete: Cascade)
  createdByUser        User?          @relation("PaymentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  processedByUser      User?          @relation("PaymentProcessedBy", fields: [processedByUserId], references: [id], onDelete: SetNull)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([studentProfileId, status])
  @@index([subscriptionId])
  @@index([dueDate])
  @@map("payments")
}

model Attendance {
  id                 String           @id @default(cuid())
  studentProfileId   String
  classScheduleId    String
  classDate          DateTime         @db.Date
  status             AttendanceStatus @default(PENDING)
  checkedInAt        DateTime?
  checkedOutAt       DateTime?
  notes              String?          @db.Text
  checkedInByUserId  String?
  checkedOutByUserId String?
  studentProfile     StudentProfile   @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  classSchedule      ClassSchedule    @relation(fields: [classScheduleId], references: [id], onDelete: Restrict)
  checkedInByUser    User?            @relation("AttendanceCheckedInBy", fields: [checkedInByUserId], references: [id], onDelete: SetNull)
  checkedOutByUser   User?            @relation("AttendanceCheckedOutBy", fields: [checkedOutByUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([studentProfileId, classScheduleId, classDate])
  @@index([classScheduleId, classDate])
  @@index([studentProfileId, classDate])
  @@index([status])
  @@map("attendances")
}

model Product {
  id                String              @id @default(cuid())
  name              String
  slug              String              @unique
  sku               String              @unique
  category          String
  shortDescription  String?             @db.Text
  description       String?             @db.Text
  status            ProductStatus       @default(ACTIVE)
  priceCents        Int
  stockQuantity     Int                 @default(0)
  lowStockThreshold Int                 @default(3)
  trackInventory    Boolean             @default(true)
  storeVisible      Boolean             @default(true)
  featured          Boolean             @default(false)
  weightGrams       Int?
  heightCm          Int?
  widthCm           Int?
  lengthCm          Int?
  images            ProductImage[]
  saleItems         ProductSaleItem[]
  cartItems         CartItem[]
  wishlistItems     WishlistItem[]
  orderItems        OrderItem[]
  inventoryMoves    InventoryMovement[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([status])
  @@index([category])
  @@index([stockQuantity])
  @@index([storeVisible, featured])
  @@index([storeVisible, status])
  @@map("products")
}

model ProductImage {
  id         String  @id @default(cuid())
  productId  String
  url        String
  storageKey String? @unique
  altText    String?
  sortOrder  Int     @default(0)
  isPrimary  Boolean @default(false)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, sortOrder])
  @@index([productId])
  @@map("product_images")
}

model ProductSale {
  id               String            @id @default(cuid())
  saleNumber       String            @unique
  studentProfileId String?
  customerName     String?
  customerDocument String?
  soldByUserId     String
  status           SaleStatus        @default(PAID)
  paymentMethod    PaymentMethod
  subtotalCents    Int
  discountCents    Int               @default(0)
  totalCents       Int
  notes            String?           @db.Text
  soldAt           DateTime          @default(now())
  cancelledAt      DateTime?
  studentProfile   StudentProfile?   @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)
  soldByUser       User              @relation("ProductSaleSoldBy", fields: [soldByUserId], references: [id], onDelete: Restrict)
  items            ProductSaleItem[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([studentProfileId])
  @@index([soldByUserId, soldAt])
  @@index([status, soldAt])
  @@map("product_sales")
}

model ProductSaleItem {
  id             String      @id @default(cuid())
  productSaleId  String
  productId      String
  quantity       Int
  unitPriceCents Int
  lineTotalCents Int
  productSale    ProductSale @relation(fields: [productSaleId], references: [id], onDelete: Cascade)
  product        Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([productSaleId, productId])
  @@index([productSaleId])
  @@index([productId])
  @@map("product_sale_items")
}

model Wishlist {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([wishlistId, productId])
  @@index([wishlistId])
  @@index([productId])
  @@map("wishlist_items")
}

model Cart {
  id           String     @id @default(cuid())
  userId       String?    @unique
  sessionToken String?    @unique
  expiresAt    DateTime?
  user         User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        CartItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([sessionToken])
  @@index([expiresAt])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model ShippingAddress {
  id             String   @id @default(cuid())
  userId         String
  label          String?
  recipientName  String
  recipientPhone String
  zipCode        String
  state          String
  city           String
  district       String
  street         String
  number         String
  complement     String?
  reference      String?
  isDefault      Boolean  @default(false)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, isDefault])
  @@index([zipCode])
  @@map("shipping_addresses")
}

model Coupon {
  id                 String             @id @default(cuid())
  code               String             @unique
  description        String?            @db.Text
  discountType       CouponDiscountType
  discountValue      Int
  active             Boolean            @default(true)
  usageLimit         Int?
  usageCount         Int                @default(0)
  perUserLimit       Int?
  minOrderValueCents Int?
  eligibleCategories String[]           @default([])
  startsAt           DateTime?
  expiresAt          DateTime?
  orders             Order[]
  redemptions        CouponRedemption[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([active, startsAt, expiresAt])
  @@map("coupons")
}

model CouponRedemption {
  id            String   @id @default(cuid())
  couponId      String
  orderId       String   @unique
  userId        String?
  discountCents Int
  coupon        Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([couponId, userId])
  @@index([userId])
  @@map("coupon_redemptions")
}

model Order {
  id                     String               @id @default(cuid())
  orderNumber            String               @unique
  userId                 String?
  couponId               String?
  status                 OrderStatus          @default(PENDING)
  paymentStatus          PaymentStatus        @default(PENDING)
  paymentMethod          PaymentMethod?
  deliveryMethod         DeliveryMethod
  deliveryLabel          String
  shippingEstimatedDays  Int?
  trackingCode           String?
  notes                  String?              @db.Text
  subtotalCents          Int
  discountCents          Int                  @default(0)
  shippingCents          Int                  @default(0)
  totalCents             Int
  currency               String               @default("BRL")
  customerName           String
  customerEmail          String
  customerPhone          String
  customerDocument       String?
  shippingAddressLabel   String?
  shippingRecipientName  String?
  shippingRecipientPhone String?
  shippingZipCode        String?
  shippingState          String?
  shippingCity           String?
  shippingDistrict       String?
  shippingStreet         String?
  shippingNumber         String?
  shippingComplement     String?
  shippingReference      String?
  placedAt               DateTime             @default(now())
  paidAt                 DateTime?
  cancelledAt            DateTime?
  deliveredAt            DateTime?
  inventoryRestoredAt    DateTime?
  user                   User?                @relation(fields: [userId], references: [id], onDelete: Restrict)
  coupon                 Coupon?              @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items                  OrderItem[]
  statusHistory          OrderStatusHistory[]
  inventoryMovements     InventoryMovement[]
  couponRedemption       CouponRedemption?
  checkoutPayment        CheckoutPayment?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([userId, placedAt])
  @@index([status, placedAt])
  @@index([paymentStatus, placedAt])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  productName     String
  productSlug     String
  productSku      String
  productCategory String
  productImageUrl String?
  quantity        Int
  unitPriceCents  Int
  lineTotalCents  Int
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt       DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id              String      @id @default(cuid())
  orderId         String
  status          OrderStatus
  note            String?     @db.Text
  changedByUserId String?
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedByUser   User?       @relation("OrderStatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime    @default(now())

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

model InventoryMovement {
  id                String                @id @default(cuid())
  productId         String
  orderId           String?
  type              InventoryMovementType
  quantityDelta     Int
  reason            String
  note              String?               @db.Text
  performedByUserId String?
  product           Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  order             Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)
  performedByUser   User?                 @relation("InventoryMovementPerformedBy", fields: [performedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime              @default(now())

  @@index([productId, createdAt])
  @@index([orderId])
  @@index([type])
  @@map("inventory_movements")
}

model CheckoutPayment {
  id                   String              @id @default(cuid())
  kind                 CheckoutPaymentKind
  provider             PaymentProvider     @default(MERCADO_PAGO)
  status               PaymentStatus       @default(PENDING)
  method               PaymentMethod?
  externalReference    String              @unique
  amountCents          Int
  providerPreferenceId String?             @unique
  providerPaymentId    String?             @unique
  checkoutUrl          String?             @db.Text
  rawPayload           Json?
  failureReason        String?             @db.Text
  paidAt               DateTime?
  refundedAt           DateTime?
  userId               String?
  orderId              String?             @unique
  subscriptionId       String?             @unique
  planId               String?
  user                 User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  order                Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  subscription         Subscription?       @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  plan                 Plan?               @relation(fields: [planId], references: [id], onDelete: SetNull)
  expense              Expense?            @relation("ExpenseCheckoutSource")
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([userId, kind, status])
  @@index([status, createdAt])
  @@index([planId])
  @@map("checkout_payments")
}

model WebhookEvent {
  id               String          @id @default(cuid())
  provider         PaymentProvider @default(MERCADO_PAGO)
  providerKey      String          @unique
  providerObjectId String?
  eventType        String?
  payload          Json?
  processed        Boolean         @default(false)
  processedAt      DateTime?
  error            String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([provider, processed, createdAt])
  @@map("webhook_events")
}

model TrainingTemplate {
  id               String               @id @default(cuid())
  name             String
  slug             String               @unique
  modalityId       String?
  teacherProfileId String?
  level            String?
  description      String?              @db.Text
  objective        String?              @db.Text
  durationMinutes  Int?
  content          Json
  isActive         Boolean              @default(true)
  modality         Modality?            @relation(fields: [modalityId], references: [id], onDelete: SetNull)
  teacherProfile   TeacherProfile?      @relation(fields: [teacherProfileId], references: [id], onDelete: SetNull)
  assignments      TrainingAssignment[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([modalityId, isActive])
  @@index([teacherProfileId])
  @@map("training_templates")
}

model TrainingAssignment {
  id                 String                   @id @default(cuid())
  studentProfileId   String
  teacherProfileId   String?
  trainingTemplateId String?
  status             TrainingAssignmentStatus @default(ASSIGNED)
  title              String
  instructions       String?                  @db.Text
  content            Json?
  assignedAt         DateTime                 @default(now())
  startAt            DateTime?
  dueAt              DateTime?
  completedAt        DateTime?
  studentNotes       String?                  @db.Text
  feedback           String?                  @db.Text
  studentProfile     StudentProfile           @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  teacherProfile     TeacherProfile?          @relation("TrainingAssignmentTeacher", fields: [teacherProfileId], references: [id], onDelete: SetNull)
  trainingTemplate   TrainingTemplate?        @relation(fields: [trainingTemplateId], references: [id], onDelete: SetNull)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([studentProfileId, status])
  @@index([teacherProfileId])
  @@index([trainingTemplateId])
  @@index([dueAt])
  @@map("training_assignments")
}

model Announcement {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  excerpt         String?
  content         String    @db.Text
  targetRole      UserRole?
  isPinned        Boolean   @default(false)
  isPublished     Boolean   @default(true)
  publishedAt     DateTime?
  expiresAt       DateTime?
  createdByUserId String
  createdByUser   User      @relation("AnnouncementCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([targetRole, isPublished, publishedAt])
  @@index([isPinned, isPublished, publishedAt])
  @@map("announcements")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  summary    String
  beforeData Json?
  afterData  Json?
  ipAddress  String?
  userAgent  String?
  actor      User?    @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}

enum BadgeRequirementType {
  TOTAL_POINTS
  CHECKIN_COUNT
  CURRENT_STREAK
  ASSESSMENT_COUNT
}

enum GamificationAction {
  CHECKIN
  STREAK_BONUS
  ASSESSMENT
  MANUAL_ADJUSTMENT
}

model StudentGamification {
  id               String         @id @default(cuid())
  studentId        String         @unique
  totalPoints      Int            @default(0)
  checkinCount     Int            @default(0)
  assessmentCount  Int            @default(0)
  currentStreak    Int            @default(0)
  longestStreak    Int            @default(0)
  lastActivityDate DateTime?      @db.Date
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  student          StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_gamification")
}

model GamificationBadge {
  id              String               @id @default(cuid())
  code            String               @unique
  name            String
  description     String               @db.Text
  iconName        String?
  requirementType BadgeRequirementType
  threshold       Int
  sortOrder       Int                  @default(0)
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  earnedBy        StudentBadge[]

  @@index([requirementType])
  @@map("gamification_badges")
}

model StudentBadge {
  id        String            @id @default(cuid())
  studentId String
  badgeId   String
  earnedAt  DateTime          @default(now())
  student   StudentProfile    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  badge     GamificationBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([studentId, badgeId])
  @@index([badgeId])
  @@map("student_badges")
}

model GamificationEvent {
  id        String             @id @default(cuid())
  studentId String
  action    GamificationAction
  points    Int
  reason    String?
  metadata  Json?
  createdAt DateTime           @default(now())
  student   StudentProfile     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@map("gamification_events")
}

model PhysicalAssessment {
  id                     String          @id @default(cuid())
  studentId              String
  assessedById           String?
  assessedAt             DateTime        @default(now())
  weightKg               Float?
  heightCm               Int?
  bodyFatPercent         Float?
  muscleMassKg           Float?
  chestCm                Float?
  waistCm                Float?
  hipCm                  Float?
  leftArmCm              Float?
  rightArmCm             Float?
  leftThighCm            Float?
  rightThighCm           Float?
  restingHeartRate       Int?
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  notes                  String?         @db.Text
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  student                StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assessedBy             TeacherProfile? @relation("AssessmentEvaluator", fields: [assessedById], references: [id], onDelete: SetNull)

  @@index([studentId, assessedAt])
  @@index([assessedById])
  @@map("physical_assessments")
}

enum ExpenseCategory {
  MP_FEE
  RENT
  PAYROLL
  MARKETING
  UTILITIES
  INFRASTRUCTURE
  TAXES
  SUPPLIES
  OTHER
}

model Expense {
  id                      String           @id @default(cuid())
  category                ExpenseCategory
  description             String
  amountCents             Int
  incurredAt              DateTime         @db.Date
  notes                   String?          @db.Text
  sourceCheckoutPaymentId String?          @unique
  createdByUserId         String?
  sourceCheckoutPayment   CheckoutPayment? @relation("ExpenseCheckoutSource", fields: [sourceCheckoutPaymentId], references: [id], onDelete: SetNull)
  createdByUser           User?            @relation("ExpenseCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@index([category, incurredAt])
  @@index([incurredAt])
  @@map("expenses")
}

enum NutritionPlanStatus {
  ACTIVE
  ARCHIVED
}

model NutritionPlan {
  id               String              @id @default(cuid())
  studentProfileId String
  createdByUserId  String?
  status           NutritionPlanStatus @default(ACTIVE)
  title            String
  description      String?             @db.Text
  content          Json
  startsAt         DateTime?           @db.Date
  endsAt           DateTime?           @db.Date
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  studentProfile   StudentProfile      @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  createdByUser    User?               @relation("NutritionPlanCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([studentProfileId, status])
  @@index([createdByUserId])
  @@map("nutrition_plans")
}

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model WhatsAppConversation {
  id                 String            @id @default(cuid())
  phone              String            @unique
  studentProfileId   String?
  contactName        String?
  unreadCount        Int               @default(0)
  lastMessageAt      DateTime?
  lastMessagePreview String?           @db.Text
  archivedAt         DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  studentProfile     StudentProfile?   @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)
  messages           WhatsAppMessage[]

  @@index([studentProfileId])
  @@index([archivedAt, lastMessageAt])
  @@map("whatsapp_conversations")
}

model WhatsAppMessage {
  id             String                   @id @default(cuid())
  conversationId String
  externalId     String?                  @unique
  direction      WhatsAppMessageDirection
  body           String                   @db.Text
  mediaUrl       String?
  mediaType      String?
  status         WhatsAppMessageStatus    @default(PENDING)
  sentByUserId   String?
  templateId     String?
  errorReason    String?
  sentAt         DateTime?
  createdAt      DateTime                 @default(now())
  conversation   WhatsAppConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentByUser     User?                    @relation("WhatsAppSentBy", fields: [sentByUserId], references: [id], onDelete: SetNull)
  template       WhatsAppTemplate?        @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@map("whatsapp_messages")
}

model WhatsAppTemplate {
  id              String            @id @default(cuid())
  name            String            @unique
  body            String            @db.Text
  category        String?
  createdByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdByUser   User?             @relation("WhatsAppTemplateCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  messages        WhatsAppMessage[]

  @@map("whatsapp_templates")
}

model Lead {
  id              String     @id @default(cuid())
  name            String
  email           String?
  phone           String?
  instagramHandle String?
  source          LeadSource @default(OTHER)
  status          LeadStatus @default(NEW)
  /// Estimated deal value in cents (BRL)
  valueCents      Int?
  /// Reason filled when status = LOST
  lostReason      String?    @db.Text
  /// Set when status transitions to WON
  convertedAt     DateTime?
  notes           String?    @db.Text
  assignedToId    String?
  createdById     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  assignedTo   User?             @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy    User?             @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  interactions LeadInteraction[]
  tasks        LeadTask[]

  @@index([status])
  @@index([source])
  @@index([assignedToId])
  @@index([createdById])
  @@index([createdAt])
  @@index([status, assignedToId])
  @@map("leads")
}

model LeadInteraction {
  id        String              @id @default(cuid())
  leadId    String
  userId    String?
  type      LeadInteractionType @default(NOTE)
  content   String              @db.Text
  createdAt DateTime            @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation("LeadInteractionBy", fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([userId])
  @@map("lead_interactions")
}

model LeadTask {
  id           String           @id @default(cuid())
  leadId       String?
  assignedToId String?
  createdById  String?
  title        String
  description  String?          @db.Text
  status       LeadTaskStatus   @default(PENDING)
  priority     LeadTaskPriority @default(MEDIUM)
  dueDate      DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  lead       Lead? @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedTo User? @relation("LeadTaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User? @relation("LeadTaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([assignedToId, status])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@map("lead_tasks")
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedById String?
  updatedBy   User?    @relation("AppSettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("app_settings")
}

model TeacherAvailability {
  id               String   @id @default(cuid())
  teacherProfileId String
  /// 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  dayOfWeek        Int
  /// HH:MM format in the academy local timezone
  startTime        String
  endTime          String
  /// Optional breaks within the slot, JSON array of { startTime, endTime }
  breaks           Json?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  teacherProfile TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)

  @@index([teacherProfileId, dayOfWeek])
  @@map("teacher_availabilities")
}

model TeacherTimeOff {
  id               String   @id @default(cuid())
  teacherProfileId String
  startsAt         DateTime
  endsAt           DateTime
  reason           String?  @db.Text
  createdAt        DateTime @default(now())

  teacherProfile TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)

  @@index([teacherProfileId, startsAt])
  @@map("teacher_time_offs")
}

model Review {
  id             String           @id @default(cuid())
  authorId       String
  targetType     ReviewTargetType
  /// References TeacherProfile.id, Modality.id, ClassSchedule.id or a free-form facility key
  targetId       String
  rating         Int
  comment        String?          @db.Text
  status         ReviewStatus     @default(PENDING)
  moderationNote String?          @db.Text
  moderatedById  String?
  moderatedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  author      User  @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  moderatedBy User? @relation("ReviewModerator", fields: [moderatedById], references: [id], onDelete: SetNull)

  @@unique([authorId, targetType, targetId])
  @@index([targetType, targetId, status])
  @@index([status, createdAt])
  @@map("reviews")
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType @default(GENERIC)
  tone       NotificationTone @default(INFO)
  title      String
  message    String           @db.Text
  href       String?
  /// Optional dedup key — same (userId, dedupKey) will not insert twice within window.
  dedupKey   String?
  metadata   Json?
  readAt     DateTime?
  archivedAt DateTime?
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupKey])
  @@index([userId, readAt, createdAt])
  @@index([userId, archivedAt])
  @@map("notifications")
}

model PushSubscription {
  id         String    @id @default(cuid())
  userId     String
  endpoint   String    @unique
  /// p256dh public key (base64)
  p256dh     String
  /// auth secret (base64)
  auth       String
  userAgent  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}
